{
	"name": "sveltekit-stripe",
	"version": "4.0.0",
	"description": "SvelteKit library for Stripe and Stripe Elements.",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/pevey/sveltekit-stripe.git"
	},
	"homepage": "https://pevey.com/sveltekit-stripe",
	"author": "Lacey Pevey",
	"license": "MIT",
	"keywords": [
		"svelte",
		"sveltekit",
		"stripe",
		"payment",
		"payments",
		"address",
		"elements",
		"pricing table",
		"checkout",
		"subscriptions",
		"ecommerce"
	],
	"type": "module",
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		},
		"./StripeElements.svelte": {
			"types": "./dist/Elements.svelte.d.ts",
			"svelte": "./dist/Elements.svelte"
		},
		"./Address.svelte": {
			"types": "./dist/AddressElement.svelte.d.ts",
			"svelte": "./dist/AddressElement.svelte"
		},
		"./Payment.svelte": {
			"types": "./dist/PaymentElement.svelte.d.ts",
			"svelte": "./dist/PaymentElement.svelte"
		}
	},
	"scripts": {
		"build": "svelte-kit sync && svelte-package && publint",
		"prepublishOnly": "npm run build",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"lint": "svelte-check --tsconfig ./tsconfig.json",
		"test:unit": "vitest run"
	},
	"peerDependencies": {
		"@stripe/stripe-js": ">=5 <10",
		"@sveltejs/kit": "^2.22.0 || ^3.0.0-next.0",
		"svelte": "^5.36.0"
	},
	"devDependencies": {
		"@stripe/stripe-js": "^9.10.0",
		"@sveltejs/adapter-auto": "8.0.0-next.1",
		"@sveltejs/kit": "3.0.0-next.10",
		"@sveltejs/package": "3.0.0-next.3",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"publint": "^0.3.0",
		"svelte": "^5.56.6",
		"svelte-check": "^4.7.3",
		"typescript": "^6.0.3",
		"vite": "^8.1.5",
		"vitest": "^4.1.10"
	}
}